# Copy to .env and adjust for your machine.
#
# Production (default): https://api.bulkmobilemart.in
# Backend runs on PORT from backend/.env (default 5001 in this project).
# Development (physical phone USB debugging): use your PC LAN IP, e.g. http://192.168.1.35:5001
# Android emulator: http://10.0.2.2:5001
# iOS simulator: http://localhost:5001
# Production (default)
API_URL=https://api.bulkmobilemart.in
STORE_URL=https://www.bulkmobilemart.in
# Local dev: http://192.168.1.35:5001 (phone) | http://10.0.2.2:5001 (Android emulator)
MERCHANT_UPI_ID=your-merchant@upi
MERCHANT_UPI_NAME=BulkMobileMart
